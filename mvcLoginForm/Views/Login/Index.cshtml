@model mvcLoginForm.Models.dto.Login
<!DOCTYPE html>
<html>
    <head>
        <meta charset="utf-8">
        <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>Login</title>
        <style>
            .login-card {
                width: 100%;
                max-height: 600px;
                max-width: 400px;
                border: 1px solid #E6E6E6;
            }
        </style>
    </head>
    <body class="bg-light">

        <div class="d-flex justify-content-center align-items-center vh-100">
            <div class="card shadow-lg p-4 login-card rounded-2 py-5">
                <div class="text-center mb-4">
                    <h2 class="fw-bold">Login</h2>
                    @if (ViewBag.Mensaje != null)
                    {
                        <div class="alert alert-danger py-2">
                            @ViewBag.Mensaje
                        </div>
                    }
                </div>

                <form method="post" action="/Login/IniciarSesion">
                    <div class="mb-3">
                        <label for="user" class="form-label fw-semibold">Usuario</label>
                        <input type="text" class="form-control" name="login" id="user" placeholder="Ej: rcastillo" required autofocus>
                    </div>
                    <div class="mb-3">
                        <label for="pass" class="form-label fw-semibold">Contraseña</label>
                        <input type="password" name="contrasena" class="form-control" id="pass" placeholder="••••••••" required>
                    </div>

                    <div class="mb-3 text-end">
                        @Html.ActionLink("¿Olvidaste tu contraseña?", "Recuperar", "Login", null, new { @class = "text-decoration-none small" })
                    </div>

                    <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Iniciar Sesión</button>
                </form>
            </div>
        </div>

        <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    </body>
</html>
    
