@model mvcLoginForm.Models.dto.Recuperar
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <meta name="viewport" content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta name="description" content="Login">
    <style>
            .login-card {
                width: 100%;
                max-height: 600px;
                max-width: 400px;
                border: 1px solid #E6E6E6;
            }
    </style>
    <title>Login</title>
</head>
<body class="bg-light">
    <div class="d-flex justify-content-center align-items-center vh-100">
        <div class="card shadow-lg p-4 login-card rounded-2 py-5">
            <div class="text-center mb-4">
                <div class="mb-2 text-start">
                    @Html.ActionLink("< Volver", "Index", "Login", null, new { @class = "text-decoration-none small" })
                </div>
                <h2 class="fw-bold">Recuperar</h2>
                @if (ViewBag.Mensaje != null)
                {
                    <div class="alert alert-danger py-2">
                        @ViewBag.Mensaje
                    </div>
                }
            </div>

            <form method="post" action="/Login/CambiarPass">
                <input type="hidden" name="id">
                <div class="mb-3">
                    <label for="user" class="form-label fw-semibold">Usuario</label>
                    <input type="text" class="form-control" name="usuario" id="user" placeholder="Ej: rcastillo" required autofocus>
                </div>
                <div class="mb-3">
                    <label for="pass" class="form-label fw-semibold">Nueva Contraseña</label>
                    <input type="password" name="contrasena" class="form-control" id="pass" placeholder="••••••••" required>
                </div>
                <div class="mb-3">
                    <label for="r_pass" class="form-label fw-semibold">Repetir Contraseña</label>
                    <input type="password" name="r_contrasena" class="form-control" id="r_pass" placeholder="••••••••" required>
                </div>
                <button type="submit" class="btn btn-primary w-100 fw-bold py-2">Establecer</button>
            </form>
        </div>
    </div>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>

</html>